# ──────────────────────────────────────────────────────────────────────
# nrdocs Platform — Wrangler Configuration
#
# Two Workers, one config file. Each Worker is an environment.
#
# Deploy:
#   wrangler deploy --env delivery
#   wrangler deploy --env control-plane
#
# Set secrets:
#   wrangler secret put HMAC_SIGNING_KEY --env delivery
#   wrangler secret put API_KEY --env control-plane
#   wrangler secret put HMAC_SIGNING_KEY --env control-plane
#   wrangler secret put TOKEN_SIGNING_KEY --env control-plane
# ──────────────────────────────────────────────────────────────────────

# Replace with your Cloudflare account ID
account_id = "REPLACE_WITH_ACCOUNT_ID"
name = "nrdocs"
compatibility_date = "2024-01-01"

# ══════════════════════════════════════════════════════════════════════
# Delivery Worker — serves docs at docs.yourdomain.com/*
# ══════════════════════════════════════════════════════════════════════

[env.delivery]
name = "nrdocs-delivery"
main = "src/delivery-worker/index.ts"

# Update this to your actual domain (or remove for *.workers.dev only)
routes = [
  { pattern = "docs.example.com/*", zone_name = "example.com" }
]

[[env.delivery.d1_databases]]
binding = "DB"
database_name = "nrdocs"
database_id = "REPLACE_WITH_D1_DATABASE_ID"

[[env.delivery.r2_buckets]]
binding = "BUCKET"
bucket_name = "nrdocs-content"

[env.delivery.vars]
SESSION_TTL = "28800"          # Session duration in seconds (default: 8 hours)
CACHE_TTL = "300"              # Cache-Control max-age in seconds (default: 5 min)
RATE_LIMIT_MAX = "5"           # Max failed login attempts before rate-limiting
RATE_LIMIT_WINDOW = "300"      # Rate-limit window in seconds (default: 5 min)

# Secrets (set via CLI, not stored here):
#   HMAC_SIGNING_KEY — signs/verifies session tokens (HMAC-SHA256)

# ══════════════════════════════════════════════════════════════════════
# Control Plane Worker — admin API for project management
# ══════════════════════════════════════════════════════════════════════

[env.control-plane]
name = "nrdocs-control-plane"
main = "src/control-plane/index.ts"

[[env.control-plane.d1_databases]]
binding = "DB"
database_name = "nrdocs"
database_id = "REPLACE_WITH_D1_DATABASE_ID"

[[env.control-plane.r2_buckets]]
binding = "BUCKET"
bucket_name = "nrdocs-content"

# Secrets (set via CLI, not stored here):
#   API_KEY            — authenticates admin API requests
#   HMAC_SIGNING_KEY   — must be the same value as the Delivery Worker
#   TOKEN_SIGNING_KEY  — signs bootstrap and repo publish tokens
