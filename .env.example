# nrdocs CLI configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — your secrets stay local.

NRDOCS_API_URL=https://nrdocs-control-plane.YOUR_SUBDOMAIN.workers.dev
NRDOCS_API_KEY=your-api-key-here
NRDOCS_PROJECT_ID=your-project-uuid-here
NRDOCS_DOCS_DIR=docs
NRDOCS_SITE_URL=https://nrdocs.example.com
