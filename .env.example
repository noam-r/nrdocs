# nrdocs platform — operator .env (nrdocs admin) — never commit this file.
# Copy to .env and fill in your values. Do not use NRDOCS_API_KEY in doc-repo CI.
#
# Run: nrdocs admin <command>   (or ./scripts/nrdocs.sh from this repo)

NRDOCS_API_URL=https://nrdocs-control-plane.YOUR_SUBDOMAIN.workers.dev
NRDOCS_API_KEY=your-api-key-here
NRDOCS_DOCS_DIR=docs
NRDOCS_SITE_URL=https://nrdocs.example.com
# Optional convenience for repeated commands against one project.
# Prefer passing the project id directly, e.g. nrdocs admin approve <project-id>
# NRDOCS_PROJECT_ID=your-project-uuid-here
# For `nrdocs admin publish` only — repo publish JWT (not the admin API key):
# NRDOCS_PUBLISH_TOKEN=
# Optional if your token binds to a repo:
# NRDOCS_REPO_IDENTITY=github.com/org/repo
